# REPLACE: change yourdomain.com to your actual domain before deploying
avasecret.org {
    encode gzip

    @api path /auth/signup /auth/signin /auth/signout /auth/forgot-password /auth/send-email-hook /auth/send-welcome /chat /chat/* /billing/* /avatars /avatars/* /preferences/* /photos/* /webhook /webhook/* /messages/* /dev/* /health*
    handle @api {
        reverse_proxy backend:8000 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
